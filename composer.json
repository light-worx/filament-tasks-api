{
    "name": "light-worx/filament-tasks",
    "description": "Filament 5 plugin for interacting with the remote Tasks API via the tasks-api-client SDK",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/support": "^11|^12|^13",
        "light-worx/tasks-api-client": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "Lightworx\\FilamentTasks\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lightworx\\FilamentTasks\\FilamentTasksServiceProvider"
            ]
        }
    }
}
